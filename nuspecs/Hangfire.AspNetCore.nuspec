<?xml version="1.0"?>
<package>
  <metadata>
    <id>Hangfire.AspNetCore</id>
    <version>%version%</version>
    <title>Hangfire ASP.NET Core Support</title>
    <authors>Sergey Odinokov</authors>
    <owners>HangfireIO, odinserj</owners>
    <projectUrl>https://www.hangfire.io/</projectUrl>
    <repository type="git" url="https://github.com/HangfireIO/Hangfire.git" commit="%commit%" />
    <license type="file">LICENSE.md</license>
    <icon>icon.png</icon>
    <description>ASP.NET Core support for Hangfire, a background job framework for .NET applications.</description>
    <copyright>Copyright ¬© 2017-2026 Hangfire O√ú</copyright>
    <tags>hangfire aspnetcore</tags>
    <releaseNotes><![CDATA[
Release notes are available in our blog https://www.hangfire.io/blog/
Please see https://docs.hangfire.io/en/latest/upgrade-guides/upgrading-to-hangfire-1.8.html to learn how to upgrade.

1.8.23
‚ÄĘ Fixed ‚Äď `InvalidOperationException`: The request reached the end of the pipeline without executing the endpoint.

1.8.22
‚ÄĘ Added ‚Äď `MapHangfireDashboardWithNoAuthorizationFilters` method, which does not include local-only filters.
‚ÄĘ Changed ‚Äď Set 404 status code when `MapHangfireDashboard` is used and no dispatcher is found.
‚ÄĘ Fixed ‚Äď `InvalidOperationException` upon receiving a request for 'hangfire/bootstrap.min.css.map'.

1.8.18
‚ÄĘ Fixed ‚Äď Swallow possible `ObjectDisposedException` in the `StopAsync` method.
‚ÄĘ Fixed ‚Äď Avoid `NullReferenceException` when `LocalIpAddress` or `RemoteIpAddress` is null.

1.8.10
‚ÄĘ Fixed ‚Äď Don't check `HasStarted` in `Response.WriteAsync` to avoid breaking dispatchers.
‚ÄĘ Project ‚Äď Enable NuGet package and DLL signing with a company certificate.
‚ÄĘ Project ‚Äď Require NuGet package signature validation on restore for dependencies.
‚ÄĘ Project ‚Äď Add `HangfireIO` as a package owner.

1.8.9
‚ÄĘ Fixed ‚Äď Don't attempt to write response headers when response has already started (by @maliming).
‚ÄĘ Project ‚Äď Enable full source link support with embedded symbols and repository-based sources.
‚ÄĘ Project ‚Äď Enable repeatable package restore using a lock file.

1.8.0
‚ÄĘ Breaking ‚Äď Make the package to be dependent on Hangfire.NetCore and use the same types.
‚ÄĘ Added ‚Äď `IApplicationBuilder.UseHangfireServer` that accepts custom factory for `IBackgroundProcessingServer`.
]]>
    </releaseNotes>
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="Hangfire.NetCore" version="[%version%]" />
      </group>
    </dependencies>
    <frameworkReferences>
      <group targetFramework="net10.0">
        <frameworkReference name="Microsoft.AspNetCore.App" />
      </group>
    </frameworkReferences>
  </metadata>
  <files>
    <file src="net10.0\Hangfire.AspNetCore.dll" target="lib\net10.0" />
    <file src="net10.0\Hangfire.AspNetCore.xml" target="lib\net10.0" />

    <file src="..\nuspecs\icon.png" />

    <file src="LICENSE.md" />
    <file src="COPYING" />
    <file src="COPYING.LESSER" />
    <file src="NOTICES" />
    <file src="LICENSE_STANDARD" />
    <file src="LICENSE_ROYALTYFREE" />
  </files>
</package>
